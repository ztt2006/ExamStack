APP_NAME=ExamStack API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/examstack
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
INITIAL_USER_POINTS=20
UPLOAD_REWARD_POINTS=5
DOWNLOAD_COST_POINTS=5
UPLOAD_DIR=backend/app/static/uploads
MAX_UPLOAD_SIZE_MB=20
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_BUCKET=
COS_PREFIX=examstack/uploads
